<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-rifas-schema" author="codex">
        <createTable tableName="rifa">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="titulo" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(2000)"/>
            <column name="cantidad_numeros" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="cantidad_ganadores" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="valor_numero" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="alias_transferencia" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="whatsapp_comprobante" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_sorteo" type="TIMESTAMP"/>
            <column name="estado" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="comprador">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="dni" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="telefono" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="compra">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rifa_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="comprador_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total" type="DECIMAL(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="estado" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_resolucion" type="TIMESTAMP"/>
        </createTable>

        <createTable tableName="premio">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rifa_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="posicion" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="descripcion" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="numero_rifa">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rifa_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="valor" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="etiqueta" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="estado" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="compra_id" type="BIGINT"/>
        </createTable>

        <createTable tableName="ganador">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="rifa_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="posicion" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="premio_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="compra_etiquetas_numeros">
            <column name="compra_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="etiquetas_numeros" type="VARCHAR(255)"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="compra" baseColumnNames="rifa_id" referencedTableName="rifa" referencedColumnNames="id" constraintName="fk_compra_rifa"/>
        <addForeignKeyConstraint baseTableName="compra" baseColumnNames="comprador_id" referencedTableName="comprador" referencedColumnNames="id" constraintName="fk_compra_comprador"/>
        <addForeignKeyConstraint baseTableName="premio" baseColumnNames="rifa_id" referencedTableName="rifa" referencedColumnNames="id" constraintName="fk_premio_rifa"/>
        <addForeignKeyConstraint baseTableName="numero_rifa" baseColumnNames="rifa_id" referencedTableName="rifa" referencedColumnNames="id" constraintName="fk_numero_rifa_rifa"/>
        <addForeignKeyConstraint baseTableName="numero_rifa" baseColumnNames="compra_id" referencedTableName="compra" referencedColumnNames="id" constraintName="fk_numero_rifa_compra"/>
        <addForeignKeyConstraint baseTableName="ganador" baseColumnNames="rifa_id" referencedTableName="rifa" referencedColumnNames="id" constraintName="fk_ganador_rifa"/>
        <addForeignKeyConstraint baseTableName="ganador" baseColumnNames="numero_id" referencedTableName="numero_rifa" referencedColumnNames="id" constraintName="fk_ganador_numero"/>
        <addForeignKeyConstraint baseTableName="ganador" baseColumnNames="premio_id" referencedTableName="premio" referencedColumnNames="id" constraintName="fk_ganador_premio"/>
        <addForeignKeyConstraint baseTableName="compra_etiquetas_numeros" baseColumnNames="compra_id" referencedTableName="compra" referencedColumnNames="id" constraintName="fk_compra_etiquetas_compra"/>

        <addUniqueConstraint tableName="numero_rifa" columnNames="rifa_id, valor" constraintName="uk_numero_rifa_rifa_valor"/>
        <addUniqueConstraint tableName="ganador" columnNames="rifa_id, posicion" constraintName="uk_ganador_rifa_posicion"/>
        <createIndex tableName="numero_rifa" indexName="idx_numero_rifa_estado">
            <column name="estado"/>
        </createIndex>
        <createIndex tableName="compra" indexName="idx_compra_estado">
            <column name="estado"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-refresh-token" author="codex">
        <createTable tableName="refresh_token">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(128)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_refresh_token_token"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_expiracion" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="revocado" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="refresh_token" indexName="idx_refresh_token_username">
            <column name="username"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-clientes-usuarios-and-rifa-ownership" author="codex">
        <createTable tableName="cliente">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_cliente_slug"/>
            </column>
            <column name="estado" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_alta" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="usuario">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(255)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_usuario_username"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="rol" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="cliente_id" type="BIGINT"/>
            <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addColumn tableName="rifa">
            <column name="slug" type="VARCHAR(255)"/>
            <column name="cliente_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="usuario" baseColumnNames="cliente_id" referencedTableName="cliente" referencedColumnNames="id" constraintName="fk_usuario_cliente"/>
        <addForeignKeyConstraint baseTableName="rifa" baseColumnNames="cliente_id" referencedTableName="cliente" referencedColumnNames="id" constraintName="fk_rifa_cliente"/>
        <addUniqueConstraint tableName="rifa" columnNames="slug" constraintName="uk_rifa_slug"/>
        <createIndex tableName="rifa" indexName="idx_rifa_cliente">
            <column name="cliente_id"/>
        </createIndex>
        <createIndex tableName="usuario" indexName="idx_usuario_cliente">
            <column name="cliente_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-add-filas-expiracion-comprobantes" author="codex">
        <addColumn tableName="rifa">
            <column name="cantidad_filas" type="INT"/>
        </addColumn>
        <sql>update rifa set cantidad_filas = cantidad_numeros where cantidad_filas is null</sql>
        <addNotNullConstraint tableName="rifa" columnName="cantidad_filas" columnDataType="INT"/>

        <createTable tableName="numero_rifa_numeros_incluidos">
            <column name="numero_rifa_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numeros_incluidos" type="VARCHAR(255)"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="numero_rifa_numeros_incluidos" baseColumnNames="numero_rifa_id" referencedTableName="numero_rifa" referencedColumnNames="id" constraintName="fk_numero_rifa_numeros_incluidos"/>

        <addColumn tableName="compra">
            <column name="fecha_expiracion" type="TIMESTAMP"/>
            <column name="comprobante_archivo" type="VARCHAR(1024)"/>
        </addColumn>
        <sql>update compra set fecha_expiracion = fecha_creacion where fecha_expiracion is null</sql>
        <addNotNullConstraint tableName="compra" columnName="fecha_expiracion" columnDataType="TIMESTAMP"/>

        <createIndex tableName="compra" indexName="idx_compra_estado_expiracion">
            <column name="estado"/>
            <column name="fecha_expiracion"/>
        </createIndex>
    </changeSet>

    <changeSet id="005-add-comprobante-whatsapp" author="codex">
        <addColumn tableName="compra">
            <column name="comprobante_whatsapp" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="comprobante_nombre_original" type="VARCHAR(255)"/>
            <column name="comprobante_content_type" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="006-add-rifa-fecha-creacion" author="codex">
        <addColumn tableName="rifa">
            <column name="fecha_creacion" type="TIMESTAMP"/>
        </addColumn>
        <sql>update rifa set fecha_creacion = current_timestamp where fecha_creacion is null</sql>
        <addNotNullConstraint tableName="rifa" columnName="fecha_creacion" columnDataType="TIMESTAMP"/>
    </changeSet>

    <changeSet id="007-add-cliente-branding" author="codex">
        <addColumn tableName="cliente">
            <column name="color_principal" type="VARCHAR(7)" defaultValue="#082d50">
                <constraints nullable="false"/>
            </column>
            <column name="logo_url" type="VARCHAR(1024)"/>
        </addColumn>
    </changeSet>

    <changeSet id="008-add-premio-imagen" author="codex">
        <addColumn tableName="premio">
            <column name="imagen_url" type="VARCHAR(1024)"/>
        </addColumn>
    </changeSet>

    <changeSet id="009-add-rifa-aclaracion-sorteo" author="codex">
        <addColumn tableName="rifa">
            <column name="aclaracion_sorteo" type="VARCHAR(2000)"/>
        </addColumn>
    </changeSet>

    <changeSet id="010-add-cliente-twilio-whatsapp" author="codex">
        <addColumn tableName="cliente">
            <column name="twilio_whatsapp_habilitado" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="twilio_whatsapp_from" type="VARCHAR(32)"/>
            <column name="twilio_messaging_service_sid" type="VARCHAR(64)"/>
            <column name="twilio_content_sid" type="VARCHAR(64)"/>
            <column name="whatsapp_consultas" type="VARCHAR(32)"/>
        </addColumn>
    </changeSet>

    <changeSet id="011-add-compra-whatsapp-automatico" author="codex">
        <addColumn tableName="compra">
            <column name="twilio_mensaje_sid" type="VARCHAR(64)"/>
            <column name="whatsapp_automatico_estado" type="VARCHAR(32)"/>
            <column name="whatsapp_automatico_error" type="VARCHAR(1000)"/>
            <column name="fecha_whatsapp_automatico" type="TIMESTAMP"/>
        </addColumn>
        <createIndex tableName="compra" indexName="idx_compra_twilio_mensaje_sid">
            <column name="twilio_mensaje_sid"/>
        </createIndex>
    </changeSet>

    <changeSet id="012-add-alias-cobro" author="codex">
        <createTable tableName="alias_cobro">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cliente_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="nombre" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="alias" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="entidad" type="VARCHAR(120)"/>
            <column name="titular" type="VARCHAR(120)"/>
            <column name="cbu_cvu" type="VARCHAR(32)"/>
            <column name="activo" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="fecha_creacion" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addColumn tableName="rifa">
            <column name="alias_cobro_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="alias_cobro" baseColumnNames="cliente_id" referencedTableName="cliente" referencedColumnNames="id" constraintName="fk_alias_cobro_cliente"/>
        <addForeignKeyConstraint baseTableName="rifa" baseColumnNames="alias_cobro_id" referencedTableName="alias_cobro" referencedColumnNames="id" constraintName="fk_rifa_alias_cobro"/>
        <addUniqueConstraint tableName="alias_cobro" columnNames="cliente_id, alias" constraintName="uk_alias_cobro_cliente_alias"/>
        <createIndex tableName="alias_cobro" indexName="idx_alias_cobro_cliente">
            <column name="cliente_id"/>
        </createIndex>
        <createIndex tableName="rifa" indexName="idx_rifa_alias_cobro">
            <column name="alias_cobro_id"/>
        </createIndex>

        <sql>
            insert into alias_cobro (cliente_id, nombre, alias, activo, fecha_creacion)
            select r.cliente_id, r.alias_transferencia, r.alias_transferencia, true, current_timestamp
            from rifa r
            where r.cliente_id is not null and r.alias_transferencia is not null
            group by r.cliente_id, r.alias_transferencia
        </sql>
        <sql>
            update rifa
            set alias_cobro_id = (
                select ac.id
                from alias_cobro ac
                where ac.cliente_id = rifa.cliente_id and lower(ac.alias) = lower(rifa.alias_transferencia)
                limit 1
            )
            where cliente_id is not null and alias_transferencia is not null
        </sql>
    </changeSet>
</databaseChangeLog>
